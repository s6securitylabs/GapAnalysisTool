{
  "name": "gap-analysis-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Static web app for mapping threat scenarios to telemetry, control coverage, gaps, and remediation actions.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:sechub": "tsc -b && vite build --base=/gaps-analysis-tool/app/",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.10.0"
}
